generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Blog {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  metaTitle       String?
  metaDescription String?
  content         String
  featuredImg     String?
  imgAlt          String?
  author          String?
  category        String?
  createdAt       DateTime @default(now())
}
